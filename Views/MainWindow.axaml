<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CircleIntersectionApp.ViewModels"
        x:Class="CircleIntersectionApp.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Пересечение окружностей - Курсовая работа"
        Width="1200" Height="800"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome">

    <Window.DataContext>
        <vm:MainWindowViewModel />
    </Window.DataContext>

    <Window.Resources>
        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#1a1a2e" Offset="0"/>
            <GradientStop Color="#16213e" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CardBackgroundBrush" StartPoint="0%,0%" EndPoint="100%,100%">
            <GradientStop Color="#0f3460" Offset="0"/>
            <GradientStop Color="#1a1a2e" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="TextColor" Color="#e8e8e8"/>
        <SolidColorBrush x:Key="SecondaryTextColor" Color="#b0b0b0"/>
        <SolidColorBrush x:Key="AccentColor" Color="#667eea"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#5a6fd8"/>
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
        </Style>

        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#4c5fd5"/>
            <Setter Property="RenderTransform" Value="scale(0.95)"/>
        </Style>

        <Style Selector="TextBox">
            <Setter Property="Background" Value="#2a2a3e"/>
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="Border.card">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BoxShadow" Value="0 4 20 0 #00000040"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextColor}"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Margin="0,0,0,20" Padding="20" BoxShadow="0 2 10 0 #00000040">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🎯 Пересечение окружностей" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="Интерактивная визуализация и анализ геометрических фигур" FontSize="14" Foreground="{StaticResource SecondaryTextColor}" Margin="0,5,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Command="{Binding LoadFileCommand}"
                            CommandParameter="{Binding $parent[Window]}"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="📂" FontSize="16"/>
                            <TextBlock Text="Загрузить" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ResetCommand}"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔄" FontSize="16"/>
                            <TextBlock Text="Сброс" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="ZoomInButton_Click"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔍+" FontSize="16"/>
                            <TextBlock Text="Увеличить" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="ZoomOutButton_Click"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🔍-" FontSize="16"/>
                            <TextBlock Text="Уменьшить" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Click="ResetViewButton_Click"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="🎯" FontSize="16"/>
                            <TextBlock Text="Сброс вида" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding SaveFileCommand}"
                            CommandParameter="{Binding $parent[Window]}"
                            Margin="0,0,8,8">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="💾" FontSize="16"/>
                            <TextBlock Text="Сохранить" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" ColumnDefinitions="1.2*,1*" RowDefinitions="*,Auto" Margin="0,0,0,20">
            <!-- Input Section -->
            <Border Grid.Row="0" Grid.Column="0" Classes="card" Margin="0,0,15,15" Padding="20">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="📝 Входные данные" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" Margin="0,0,0,15"/>

                    <TextBox Grid.Row="1"
                             Text="{Binding InputData, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="200"
                             Watermark="Введите координаты и радиусы окружностей..."
                             ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                    <Border Grid.Row="2" Background="#1a1a2e" CornerRadius="8" Margin="0,15,0,0" Padding="15" BorderBrush="#404040" BorderThickness="1">
                        <StackPanel Spacing="10">
                            <TextBlock Text="💡 Формат ввода:" FontWeight="SemiBold" Foreground="{StaticResource TextColor}"/>
                            <TextBlock Text="x₁ y₁ r₁" FontFamily="Consolas" Foreground="#27ae60"/>
                            <TextBlock Text="x₂ y₂ r₂" FontFamily="Consolas" Foreground="#e74c3c"/>
                            <TextBlock Text="Пример:" FontWeight="SemiBold" Margin="0,10,0,0" Foreground="{StaticResource TextColor}"/>
                            <TextBlock Text="0 0 5" FontFamily="Consolas" Foreground="{StaticResource AccentColor}"/>
                            <TextBlock Text="8 0 5" FontFamily="Consolas" Foreground="#e67e22"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Graph Section -->
            <Border Grid.Row="0" Grid.Column="1" Classes="card" Margin="0,0,0,15" Padding="20">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="📊 Визуализация" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" Margin="0,0,0,15"/>

                    <Border Grid.Row="1" Background="{StaticResource CardBackgroundBrush}" CornerRadius="8" Padding="2">
                        <ScrollViewer x:Name="GraphScrollViewer"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#0f0f23">
                            <Canvas x:Name="GraphCanvas"
                                    Background="#0f0f23"
                                    Width="800"
                                    Height="600"
                                    PointerWheelChanged="GraphCanvas_PointerWheelChanged"
                                    PointerPressed="GraphCanvas_PointerPressed"
                                    PointerMoved="GraphCanvas_PointerMoved"
                                    PointerReleased="GraphCanvas_PointerReleased"
                                    SizeChanged="GraphCanvas_SizeChanged"/>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!-- Results Section -->
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Classes="card" Padding="20">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="📋 Результаты анализа" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextColor}" Margin="0,0,0,15"/>

                    <TextBox Grid.Row="1"
                             Text="{Binding OutputResult, Mode=OneWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             MinHeight="120"
                             Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="13"
                             Foreground="{StaticResource TextColor}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{StaticResource CardBackgroundBrush}" CornerRadius="12" Padding="15" BoxShadow="0 2 10 0 #00000040">
            <TextBlock Text="🎓 КУРСОВАЯ РАБОТА
по дисциплине «Языки, технологи и методы программирования»
 | Разработка прикладной программы на языке программирования C#"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource SecondaryTextColor}"
                       FontSize="12"/>
        </Border>
    </Grid>
</Window>